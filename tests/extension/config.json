{
    "configuration_url": "config.json",
    "identifier": "rex-page-manipulation-test",
    "page_manipulation": {
        "enabled": true,
        "debug": true,
        "obscure_page": [{
            "base_url": "https://archive.org/",
            "delay": 1500
        }],
        "url_redirects": [{
            "url_filter": "||coca-cola.com"
        }],
        "url_redirects_old": [{
            "url_filter": "||coca-cola.com",
            "destination": "https://www.pepsi.com/"
        }],
        "page_elements": [{
          "base_url": "https://www.wikipedia.org/",
          "actions": [{
            "selector": "#js-link-box-en",
            "action": "hide"
          }]
        }, {
          "base_url": "http://localhost:8080/links.html",
          "actions": [{
            "selector": "#link-0",
            "action": "add_class"
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "hash_test_marker",
            "content": { "source": "attr", "name": "href", "transform": "domain" },
            "fraction": 0.2,
            "precision": 8
          }, {
            "action": "add_class",
            "selector": "li[id^='li-']",
            "class_name": "hash_test_within_marker",
            "content": { "source": "attr", "name": "href", "transform": "domain", "within": "a" },
            "fraction": 0.2,
            "precision": 8
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "hash_offset_marker",
            "content": { "source": "attr", "name": "href", "transform": "domain" },
            "offset": 0.2,
            "fraction": 0.2,
            "precision": 8
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "hash_exception_marker",
            "content": { "source": "attr", "name": "href", "transform": "domain" },
            "fraction": 0.2,
            "precision": 8,
            "exceptions": ["youtube.com"]
          }]
        }]
    },
    "ui": [{
        "title": "REX Page Manipulation Testing Extension",
        "identifier": "main",
        "default": true
    }]
}
