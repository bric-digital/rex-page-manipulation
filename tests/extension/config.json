{
    "configuration_url": "config.json",
    "identifier": "rex-page-manipulation-test",
    "page_manipulation": {
        "enabled": true,
        "debug": true,
        "obscure_page": [{
            "base_url": "https://archive.org/",
            "delay": 1500
        }],
        "url_redirects": [{
            "url_filter": "||coca-cola.com"
        }],
        "url_redirects_old": [{
            "url_filter": "||coca-cola.com",
            "destination": "https://www.pepsi.com/"
        }],
        "page_elements": [{
          "base_url": "https://www.wikipedia.org/",
          "actions": [{
            "selector": "#js-link-box-en",
            "action": "hide"
          }]
        }, {
          "base_url": "http://localhost:8080/links.html",
          "actions": [{
            "selector": "#link-0",
            "action": "add_class"
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "range_marker",
            "conditions": [{
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [0, 8],
              "within_range": ["00000000", "40000000"]
            }]
          }, {
            "action": "add_class",
            "selector": "li[id^='li-']",
            "class_name": "within_marker",
            "conditions": [{
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain", "within": "a" },
              "use": [0, 8],
              "within_range": ["00000000", "40000000"]
            }]
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "exception_marker",
            "conditions": [{
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [0, 8],
              "within_range": ["00000000", "40000000"]
            }],
            "exceptions": ["wikipedia.org"]
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "all_marker",
            "conditions_match": "all",
            "conditions": [{
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [0, 8],
              "within_range": ["00000000", "80000000"]
            }, {
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [8, 16],
              "within_range": ["00000000", "80000000"]
            }]
          }, {
            "action": "add_class",
            "selector": "a[id^='link-']",
            "class_name": "any_marker",
            "conditions_match": "any",
            "conditions": [{
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [0, 8],
              "within_range": ["00000000", "80000000"]
            }, {
              "operation": "calculate-sha512-hash",
              "content": { "source": "attr", "name": "href", "transform": "domain" },
              "use": [8, 16],
              "within_range": ["00000000", "80000000"]
            }]
          }]
        }]
    },
    "ui": [{
        "title": "REX Page Manipulation Testing Extension",
        "identifier": "main",
        "default": true
    }]
}
